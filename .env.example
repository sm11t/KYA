# KYA — Environment Variables

# Server
PORT=3456
HOST=localhost

# Agent Identity
JWT_SECRET=change-me-to-a-random-secret

# Downstream MCP server (the real MCP server KYA proxies to)
UPSTREAM_MCP_URL=http://localhost:4001/mcp

# Policy directory (JSON files)
POLICY_DIR=./policies

# Database
DB_PATH=./kya.sqlite
